# ═════════════════════════════════════════════════════════════════════════════
# Cerebro Medical Platform - Environment Configuration Example
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and update the values for your environment

# ─────────────────────────────────────────────────────────────────────────────
# FHIR Server Integration
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of your FHIR R4 compliant server
# Examples:
#   - http://localhost:8080/fhir (HAPI FHIR Local)
#   - https://fhir.epic.com (Epic)
#   - https://fhir.cerner.com (Cerner)
FHIR_SERVER_URL=http://localhost:8080/fhir

# Optional: Bearer token for FHIR server authentication
# Leave empty if your FHIR server doesn't require authentication
FHIR_SERVER_AUTH_TOKEN=

# Request timeout in seconds (default: 30)
FHIR_SERVER_TIMEOUT=30

# Enable or disable FHIR synchronization
# Set to False to run in local-only mode (no FHIR server)
FHIR_SYNC_ENABLED=True

# ─────────────────────────────────────────────────────────────────────────────
# Django Settings (Optional - defaults are used if not set)
# ─────────────────────────────────────────────────────────────────────────────

# Django debug mode (set to False in production)
DEBUG=True

# Django secret key (auto-generated in settings.py)
# SECRET_KEY=your-secret-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# For production, consider PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/cerebro

# ─────────────────────────────────────────────────────────────────────────────
# QUICK START
# ─────────────────────────────────────────────────────────────────────────────

# 1. Start FHIR Server (HAPI FHIR with Docker):
#    docker run -d -p 8080:8080 --name hapi-fhir hapiproject/hapi:latest

# 2. Verify FHIR server is running:
#    curl http://localhost:8080/fhir/metadata

# 3. Export environment variables:
#    export FHIR_SERVER_URL=http://localhost:8080/fhir
#    export FHIR_SYNC_ENABLED=True

# 4. Run Django migrations:
#    python manage.py migrate

# 5. Start development servers:
#    python manage.py runserver  # Backend on :8000
#    npm run dev                 # Frontend on :5173

# 6. Test the flow:
#    - Sign up as doctor and patient
#    - Patient books appointment
#    - Check console for FHIR sync logs
#    - Doctor refreshes dashboard → see FHIR appointments
